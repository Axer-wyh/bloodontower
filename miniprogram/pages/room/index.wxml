<view class="page-shell">
  <view class="hero-card">
    <view class="pill">v0.2 真实房间</view>
    <view class="hero-title">房间大厅</view>
    <view class="hero-subtitle">
      通过云函数创建/加入房间，页面会按当前微信用户身份返回主持视图、玩家视图或公开视图。
    </view>
  </view>

  <view class="panel-card form-card">
    <view class="nav-card-title">创建房间</view>
    <view class="form-field">
      <text class="form-label">主持昵称</text>
      <input class="input" value="{{hostName}}" data-field="hostName" bindinput="updateField" placeholder="输入主持昵称" />
    </view>
    <view class="form-field">
      <text class="form-label">座位数</text>
      <input class="input" type="number" value="{{seatCount}}" data-field="seatCount" bindinput="updateField" />
    </view>
    <view class="button-row">
      <button class="button-primary" loading="{{loading}}" bindtap="createRoom">创建房间</button>
      <button class="button-secondary" bindtap="refreshRoom">刷新当前房间</button>
    </view>
  </view>

  <view class="panel-card form-card">
    <view class="nav-card-title">加入房间</view>
    <view class="form-field">
      <text class="form-label">房间 ID</text>
      <input class="input" value="{{roomIdInput}}" data-field="roomIdInput" bindinput="updateField" placeholder="输入 roomId" />
    </view>
    <view class="form-field">
      <text class="form-label">玩家昵称</text>
      <input class="input" value="{{joinName}}" data-field="joinName" bindinput="updateField" placeholder="输入玩家昵称" />
    </view>
    <view class="button-row">
      <button class="button-primary" loading="{{loading}}" bindtap="joinRoom">加入房间</button>
      <button wx:if="{{currentRoomId}}" class="button-secondary" bindtap="openHostPanel">打开主持台</button>
      <button wx:if="{{currentRoomId}}" class="button-secondary" bindtap="openPlayerPanel">打开玩家面板</button>
    </view>
  </view>

  <view wx:if="{{error}}" class="error-box">{{error}}</view>

  <view wx:if="{{room}}">
    <view class="section-title">当前房间</view>
    <view class="panel-card list-card">
      <view class="row">
        <view class="nav-card-title">{{room.scriptName}}</view>
        <view class="pill">{{viewerRole}}</view>
      </view>
      <view class="nav-card-desc">
        房间 {{room.roomId}} · 状态 {{room.statusLabel}} · 阶段 {{room.phaseLabel}} · 第 {{room.day}} 天
      </view>
    </view>

    <view class="section-title">玩家</view>
    <view wx:for="{{room.players}}" wx:key="playerId" class="panel-card list-card">
      <view class="row">
        <view class="nav-card-title">{{item.seat}} 号 {{item.name}}</view>
        <view class="pill">{{item.isAlive ? "存活" : "死亡"}}</view>
      </view>
      <view class="nav-card-desc">{{item.visibleRoleName}}</view>
    </view>

    <view class="section-title">公开日志</view>
    <view wx:for="{{room.publicLog}}" wx:key="logId" class="timeline-item">
      <view class="nav-card-title">{{item.title}}</view>
      <view class="muted small">{{item.message}}</view>
    </view>
  </view>
  <view wx:else class="panel-card empty-box">
    创建房间或输入 roomId 加入后，这里会展示持久化的真实房间状态。
  </view>
</view>

<view class="page-shell">
  <view class="hero-card">
    <view class="pill">{{script.nameEn}}</view>
    <view class="hero-title">{{script.name}}</view>
    <view class="hero-subtitle">{{script.summary}}</view>
    <view class="hero-subtitle small">官方来源：{{script.sourceLink}}</view>
  </view>

  <view class="section-title">术语</view>
  <view wx:for="{{script.terms}}" wx:key="term" class="panel-card list-card">
    <view class="row">
      <view class="nav-card-title">{{item.term}}</view>
      <view class="pill">{{item.category}}</view>
    </view>
    <view class="nav-card-desc">{{item.summary}}</view>
  </view>

  <view class="section-title">规则索引</view>
  <view wx:for="{{script.ruleIndex}}" wx:key="title" class="panel-card list-card">
    <view class="nav-card-title">{{item.title}}</view>
    <view class="nav-card-desc">{{item.summary}}</view>
    <view class="tag-row">
      <view wx:for="{{item.keywords}}" wx:key="*this" class="tag">{{item}}</view>
    </view>
    <view class="muted small">来源：{{item.sourceLink}}</view>
  </view>

  <view class="section-title">FAQ</view>
  <view wx:for="{{script.faq}}" wx:key="question" class="panel-card list-card">
    <view class="nav-card-title">{{item.question}}</view>
    <view class="nav-card-desc">{{item.answer}}</view>
  </view>
</view>


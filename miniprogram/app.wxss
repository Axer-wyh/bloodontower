page {
  --bg: #f4efe5;
  --ink: #241b18;
  --accent: #8f1d1d;
  --accent-soft: #d6b38d;
  --panel: rgba(255, 250, 244, 0.9);
  --line: rgba(50, 35, 29, 0.12);
  background:
    radial-gradient(circle at top left, rgba(143, 29, 29, 0.14), transparent 32%),
    radial-gradient(circle at bottom right, rgba(35, 51, 74, 0.1), transparent 28%),
    linear-gradient(180deg, #f9f2e8 0%, #efe5d6 100%);
  color: var(--ink);
  min-height: 100%;
  font-family: "Avenir Next", "PingFang SC", sans-serif;
}

.page-shell {
  padding: 32rpx 28rpx 40rpx;
}

.hero-card,
.panel-card {
  background: var(--panel);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(36, 27, 24, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(36, 27, 24, 0.72);
  line-height: 1.6;
}

.section-title {
  margin: 22rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.grid-links {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.nav-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(244, 232, 219, 0.95));
  border: 1rpx solid rgba(143, 29, 29, 0.12);
}

.nav-card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.nav-card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(36, 27, 24, 0.7);
  line-height: 1.5;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 29, 29, 0.08);
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 600;
}

.list-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.muted {
  color: rgba(36, 27, 24, 0.68);
}

.small {
  font-size: 22rpx;
}

.role-chip {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(35, 51, 74, 0.12), rgba(143, 29, 29, 0.12));
  font-size: 22rpx;
  font-weight: 700;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(36, 27, 24, 0.06);
  font-size: 22rpx;
}

.timeline-item {
  position: relative;
  padding-left: 26rpx;
  margin-bottom: 18rpx;
}

.timeline-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--accent);
}

